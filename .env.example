# UTO Backend Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to git!

# Google Maps API
GOOGLE_PLACES_API_KEY=your_google_api_key_here

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Server URL (update this to your Railway URL after deployment)
EXPO_PUBLIC_DOMAIN=https://api.uto.taxi
EXPO_PUBLIC_API_URL=https://api.uto.taxi

# Stripe
STRIPE_SECRET_KEY=your_stripe_secret_key_here
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key_here

# Port (Railway sets this automatically, default 5000 for local dev)
PORT=5000
